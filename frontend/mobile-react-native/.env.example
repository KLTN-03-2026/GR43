# =============================================================
# DATN 2026 - Mobile App Environment Variables
# =============================================================
# SAO CHÉP file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git!
# =============================================================

# --- API Backend ---
# Local dev (iOS Simulator): dùng localhost
# Local dev (điện thoại thật): dùng IP máy tính (vd: 192.168.1.x)
# Production: dùng domain thật
EXPO_PUBLIC_API_BASE_URL=http://localhost:5017

# --- Google OAuth2 ---
# Lấy từ Google Cloud Console > OAuth 2.0 Client IDs
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# --- App Config ---
EXPO_PUBLIC_APP_ENV=development
